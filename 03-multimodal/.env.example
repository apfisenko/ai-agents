# Скопируйте в .env и задайте значения. Не коммитьте .env.

# --- Прокси / VPN (если без этого бот не доходит до api.telegram.org / OpenRouter) ---
# Укажите URL с схемой или только хост:порт (будет добавлено http://):
#   HTTPS_PROXY=http://127.0.0.1:11301   (часто с netsh 11301->реальный_порт; см. ReadMe)
#   HTTPS_PROXY=http://127.0.0.1:1301
# Один .env: и `uv run`, и Docker. В Docker тот же HTTPS_PROXY указывает на прокси на Windows; при ClientProxyConnectionError
# — ReadMe (Allow LAN, netsh portproxy). AIDD_DOCKER_DIRECT_NETWORK в docker-compose — только если в контейнере к Telegram
# путь без прокси, а в .env прокси оставлен ради `uv run` на хосте.
# AIDD_WINDOWS_PROXY_HOST: при Docker+wsl + ошибке 172.17.0.1 — IP Windows из: PowerShell: .\make.ps1 docker-windows-host-ip
# AIDD_DOCKER_DIRECT_NETWORK=1: только в docker-compose, если в контейнере без прокси, а .env с прокси — для `uv run`
HTTPS_PROXY=
HTTP_PROXY=
AIDD_DOCKER_DIRECT_NETWORK=
AIDD_WINDOWS_PROXY_HOST=

TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# --- LLM: OpenRouter ИЛИ Ollama (и любой OpenAI-compatible /v1) ---
# Переключение только через эту троицу (+ модели). Имена переменных — именно OPENROUTER_* и LLM_* (код не читает OPENAI_* / MODEL_TEXT / MODEL_IMAGE).
#
# Пример A — OpenRouter (по умолчанию):
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_VISION_MODEL=
LLM_AUDIO_MODEL=
#
# Пример B — Ollama на удалённом/локальном GPU (подставьте хост; порт обычно 11434; путь должен заканчиваться на /v1):
# OPENROUTER_API_KEY=ollama
# OPENROUTER_BASE_URL=http://192.0.2.10:11434/v1
# LLM_MODEL=qwen2.5:7b-instruct
# LLM_VISION_MODEL=qwen3-vl:8b-instruct
# LLM_AUDIO_MODEL=
#
# Только текстовые сообщения (structured output и диалог): имя модели у выбранного провайдера.
# Только фото чеков (VLM): LLM_VISION_MODEL; если пусто — то же имя, что LLM_MODEL.
# Голосовые сообщения (аудио в LLM, input_audio): LLM_AUDIO_MODEL; если пусто — то же имя, что LLM_MODEL.
# Нужна модель с входом audio (см. каталог моделей провайдера). Telegram шлёт обычно OGG Opus — для OpenRouter укажите format ogg; строгий OpenAI chat иногда принимает только wav/mp3.
# Пример разделения на OpenRouter: LLM_MODEL=… (дешёвая для текста), LLM_VISION_MODEL=openai/gpt-4o-mini (vision), LLM_AUDIO_MODEL=… (с audio input).

# Максимум токенов в ответе модели (chat completions: max_tokens в API). Обязательно в .env: целое 64–8192.
LLM_MAX_COMPLETION_TOKENS=1024
# Отдельный лимит ответа только для фото чеков (VLM). Если не задан — max(LLM_MAX_COMPLETION_TOKENS, 2048), но не выше 8192.
# При finish_reason=length и пустом ответе увеличьте (reasoning-модели «съедают» лимит до JSON).
LLM_VISION_MAX_COMPLETION_TOKENS=
# Отдельный лимит для голосовых (аудио в LLM). Если не задан — как у VLM: max(LLM_MAX_COMPLETION_TOKENS, 2048), не выше 8192.
LLM_AUDIO_MAX_COMPLETION_TOKENS=
# Таймаут HTTP к LLM (сек.). Не задавайте — будет поведение SDK по умолчанию (~600 с чтение).
# Явное значение — диапазон 30–600 (например 120 для контейнеров с медленным OpenRouter).
LLM_HTTP_TIMEOUT_SECONDS=
# Путь к файлу с системным промптом (от корня репозитория или абсолютный)
SYSTEM_PROMPT_PATH=prompts/system.txt
# Валюта по умолчанию для сумм без явного кода (ISO 4217). Можно не задавать — будет RUB.
DEFAULT_CURRENCY=RUB
# По умолчанию в коде: INFO
LOG_LEVEL=INFO
# Таймаут HTTP к Telegram (сек.), по умолчанию 60. Не устраняет блокировку/отсутствие маршрута из Docker.
# TELEGRAM_HTTP_TIMEOUT=90
