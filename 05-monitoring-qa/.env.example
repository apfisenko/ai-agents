# Скопируйте в .env и задайте значения. Не коммитьте .env.

# --- Прокси / VPN (если без этого бот не доходит до api.telegram.org / OpenRouter) ---
# Укажите URL с схемой или только хост:порт (будет добавлено http://):
#   HTTPS_PROXY=http://127.0.0.1:11301   (часто с netsh 11301->реальный_порт; см. ReadMe)
#   HTTPS_PROXY=http://127.0.0.1:1301
# Один .env: и `uv run`, и Docker. В Docker тот же HTTPS_PROXY указывает на прокси на Windows; при ClientProxyConnectionError
# — ReadMe (Allow LAN, netsh portproxy). AIDD_DOCKER_DIRECT_NETWORK в docker-compose — только если в контейнере к Telegram
# путь без прокси, а в .env прокси оставлен ради `uv run` на хосте.
# AIDD_WINDOWS_PROXY_HOST: при Docker+wsl + ошибке 172.17.0.1 — IP Windows из: PowerShell: .\make.ps1 docker-windows-host-ip
# AIDD_DOCKER_DIRECT_NETWORK=1: только в docker-compose, если в контейнере без прокси, а .env с прокси — для `uv run`
HTTPS_PROXY=
HTTP_PROXY=
AIDD_DOCKER_DIRECT_NETWORK=
AIDD_WINDOWS_PROXY_HOST=

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPEN_API_KEY=your_openrouter_key
LLM_MODEL=openai/gpt-4o-mini
# Опционально: отдельная модель для шага query transform в RAG; если не задано — используется LLM_MODEL
# LLM_QUERY_TRANSFORM_MODEL=openai/gpt-4o-mini
OPEN_BASE_URL=https://openrouter.ai/api/v1
# Топ-K документов для retriever (RAG), целое 1–50 (используется с итерации 7)
RETRIEVER_K=5
# Показывать в ответе строку с использованными документами (файл, страницы). true / 1 / yes — включено
SHOW_SOURCES=false

# --- LangSmith / трейсинг LangChain (опционально, docs/vision.md §9 и «Мониторинг…», п. 2) ---
# Прогоны RAG уходят в проект LangSmith без правок цепочки: клиент читает env при старте процесса.
# Если ключ и TRACING выключены / не заданы — работа бота без изменений.
# Включить трейсинг (достаточно true; поддерживаются и префикс LANGCHAIN_*, см. LangSmith SDK):
# LANGSMITH_TRACING_V2=true
# Ключ LangSmith / LangChain (формат «Bearer» не нужен — только значение ключа):
# LANGSMITH_API_KEY=your_langsmith_api_key
# Имя проекта в LangSmith для группировки трейсов (если не задано — дефолт клиента LangSmith):
# LANGSMITH_PROJECT=aidd-bot
# При EU-instance / self-hosted задайте базовый URL API (см. документацию LangSmith):
# LANGSMITH_ENDPOINT=https://...
#
# Выгрузка датасета (`make dataset-upload`, docs/vision.md §10): имя набора и описание в LangSmith
# LANGSMITH_DATASET_NAME=05-rag-qa-dataset
# LANGSMITH_DATASET_DESCRIPTION=Q&A для оценки RAG (aidd)

# --- RAGAS / команда Telegram /evaluate_dataset (docs/vision.md §10 п.4) ---
# Нужны LANGSMITH_API_KEY и датасет в LangSmith (имя — LANGSMITH_DATASET_NAME; загрузка: make dataset-upload).
# RAGAS_LLM_MODEL=openai/gpt-4o-mini
# RAGAS_EMBEDDING_MODEL=openai/text-embedding-3-small
# Полоса RAGAS «Evaluating» по умолчанию выключена; 1 — включить tqdm (удобно в обычном терминале).
# RAGAS_SHOW_PROGRESS=1
# Параллельные задачи RAGAS (осторожно с лимитами API; по умолчанию в коде 1).
# RAGAS_MAX_WORKERS=2
# Число примеров за один прогон (по умолчанию в коде 30; all — весь набор, см. EVAL_MAX_EXAMPLES в evaluation.py)
# EVAL_MAX_EXAMPLES=30

# Модель эмбеддингов для RAG (OpenRouter / OpenAI-compatible). По умолчанию в коде: openai/text-embedding-3-small
# EMBEDDING_MODEL=openai/text-embedding-3-small
# Индексация (эмбеддинги): таймаут HTTP в секундах (по умолчанию 180), размер батча (по умолчанию 64), число ретраев (по умолчанию 5)
# EMBEDDING_REQUEST_TIMEOUT=240
# EMBEDDING_BATCH_SIZE=32
# EMBEDDING_MAX_RETRIES=8
# Опционально: каталог с PDF/JSON для RAG (иначе ищется папка data/ от cwd вверх)
# DATA_DIR=./data
# Максимум токенов в ответе модели (chat completions: max_tokens в API). Обязательно в .env: целое 64–8192.
LLM_MAX_COMPLETION_TOKENS=1024
# Путь к файлу с системным промптом (от корня репозитория или абсолютный)
SYSTEM_PROMPT_PATH=prompts/system.txt
# По умолчанию в коде: INFO
LOG_LEVEL=INFO
# Таймаут HTTP к Telegram (сек.), по умолчанию 60. Не устраняет блокировку/отсутствие маршрута из Docker.
# TELEGRAM_HTTP_TIMEOUT=90
